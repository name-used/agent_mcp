{
  "allow_roots": [
    "/path_to/sand_box"
  ],
  "deny_paths": [
    "/path_to/sand_box/deny_path"
  ],
  "blocked_extensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".bmp",
    ".webp",
    ".pdf",
    ".zip",
    ".tar",
    ".gz",
    ".7z",
    ".rar",
    ".npy",
    ".npz",
    ".pt",
    ".pth",
    ".ckpt",
    ".safetensors",
    ".gguf",
    ".bin",
    ".so",
    ".dll",
    ".exe"
  ],
  "run_python": {
    "enabled": false,
    "python_bin": "/path_to/python",
    "cwd": "/path_to/sand_box",
    "allow_paths": [
      "/path_to/sand_box/project/main_runner.py",
      "/path_to/sand_box/project/tools/agent_entry"
    ],
    "deny_paths": [
      "/path_to/sand_box/.git",
      "/path_to/sand_box/project/data",
      "/path_to/sand_box/project/weights",
      "/path_to/sand_box/project/checkpoints"
    ],
    "max_timeout_sec": 3600,
    "max_stdout_chars": 12000,
    "max_stderr_chars": 12000,
    "max_args": 64,
    "max_arg_len": 1024,
    "inherit_env": true,
    "extra_env": {
      "PYTHONNOUSERSITE": "1"
    }
  }
}