{
  "allow_roots": [
    "/path_to/sand_box",
    "/path_to/memory_box/",
    "/root/.qwenpaw/workspaces/"
  ],
  "deny_paths": [],
  "blocked_extensions": [
    ".exe",
    ".dll",
    ".so",
    ".dylib",
    ".pyd"
  ],
  "features": {
    "create_file": true,
    "append_file": true,
    "rewrite_file": true,
    "replace_file": true,
    "delete_file": true,
    "read_file": true,
    "list_dir": true,
    "grep_text": true,
    "readonly_cmd": true,
    "git_status": true,
    "git_log": true,
    "git_diff": true,
    "run_python": true
  },
  "run_cmd": {
    "enabled": true,
    "max_timeout_sec": 10,
    "max_stdout_chars": 12000,
    "max_stderr_chars": 8000,
    "max_args": 64,
    "max_arg_len": 1024,
    "commands": {
      "ls": {
        "bin": "/usr/bin/ls"
      },
      "ll": {
        "bin": "/usr/bin/ls"
      },
      "grep": {
        "bin": "/usr/bin/grep"
      }
    }
  },
  "run_python": {
    "enabled": true,
    "python_bin": "/path_to/python",
    "cwd": "/path_to/sand_box",
    "allow_paths": [
      "/path_to/sand_box/main_feat.py",
      "/path_to/sand_box/main_train.py",
      "/path_to/sand_box/metric_show.py",
      "/path_to/sand_box/check_data_info.py",
      "/path_to/sand_box/tests"
    ],
    "deny_paths": [
      "/path_to/sand_box/.git"
    ],
    "max_timeout_sec": 3600,
    "max_stdout_chars": 12000,
    "max_stderr_chars": 12000,
    "max_args": 64,
    "max_arg_len": 1024,
    "inherit_env": true,
    "extra_env": {}
  }
}